# Copy this file to `.env.local` and fill in values (never commit `.env.local`).

# --- Gemini API keys ---
# Primary text + multimodal key
GOOGLE_GEMINI_API_KEY=
# Optional dedicated image key (Nano Banana, if issued separately)
NANO_BANANA_API_KEY=
# Legacy fallback (kept for backward compatibility)
# GEMINI_API_KEY=

# Optional overrides (defaults work for most demos)
# GEMINI_TEXT_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# --- App URL (used by buyer-agent script; optional for Next) ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- MoneyDevKit / Lightning (required for /api/generate paywall + buyer-agent) ---
MDK_ACCESS_TOKEN=
MDK_MNEMONIC=

# --- Local admin testing (skip L402 payment challenge) ---
# SKIP_L402_DEV=1

# --- Vercel / Upstash Redis (optional locally; recommended on Vercel for persistence) ---
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

