# Copy this file to `.env.local` and fill in values (never commit `.env.local`).

# --- Gemini (required for ingest + generation) ---
GEMINI_API_KEY=

# Optional overrides (defaults work for most demos)
# GEMINI_TEXT_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# --- App URL (used by buyer-agent script; optional for Next) ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- MoneyDevKit / Lightning (required for /api/generate paywall + buyer-agent) ---
MDK_ACCESS_TOKEN=
MDK_MNEMONIC=

# --- Local development bypass (DO NOT ENABLE IN PRODUCTION) ---
# Set to 1 to skip L402 in /api/generate and /api/generate/fusion for local testing.
# SKIP_L402_DEV=1

# --- Vercel / Upstash Redis (optional locally; recommended on Vercel for persistence) ---
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
